# Set these on your Convex deployment with `convex env set` or in the dashboard.

# 32-byte secret, encoded as base64/base64url or 64-char hex.
RELAY_ENC_KEY=replace-me

# Comma-separated bundle allowlist. Official OpenClaw/TestFlight builds use ai.openclaw.client.
RELAY_ALLOWED_BUNDLE_IDS=ai.openclaw.client

# Apple team used for App Attest verification.
APPLE_TEAM_ID=TEAMID1234

# Set to true only for non-production testing with development App Attest attestations.
APP_ATTEST_ALLOW_DEV=false

# APNs auth key for production/TestFlight delivery.
APNS_TEAM_ID=TEAMID1234
APNS_KEY_ID=ABC123XYZ9
APNS_P8=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----

# Optional. Only needed if your app's receipt validation flow requires the shared secret.
# APPLE_RECEIPT_SECRET=

# Optional tuning overrides.
HANDLE_TTL_MS=2592000000
CHALLENGE_TTL_MS=300000
RATE_LIMIT_WINDOW_MS=60000
CHALLENGE_RATE_LIMIT_MAX=30
REGISTER_RATE_LIMIT_MAX=10
SEND_RATE_LIMIT_MAX=120
