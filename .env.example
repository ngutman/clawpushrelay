CLAWPUSHRELAY_HOST=127.0.0.1
CLAWPUSHRELAY_PORT=8787
CLAWPUSHRELAY_TRUST_PROXY=false
CLAWPUSHRELAY_STATE_DIR=./data

# 32-byte secret, encoded as base64/base64url or 64-char hex.
CLAWPUSHRELAY_ENCRYPTION_KEY=replace-me

# Bearer token shared with the OpenClaw gateway for POST /v1/push/send.
CLAWPUSHRELAY_GATEWAY_BEARER_TOKEN=replace-me

# Comma-separated bundle allowlist. Official OpenClaw/TestFlight builds use ai.openclaw.client.
CLAWPUSHRELAY_ALLOWED_BUNDLE_IDS=ai.openclaw.client

# Apple team used for App Attest verification.
CLAWPUSHRELAY_APPLE_TEAM_ID=TEAMID1234

# Set to true only for non-production testing with development App Attest attestations.
CLAWPUSHRELAY_APP_ATTEST_ALLOW_DEVELOPMENT=false

# APNs auth key for production/TestFlight delivery.
CLAWPUSHRELAY_APNS_TEAM_ID=TEAMID1234
CLAWPUSHRELAY_APNS_KEY_ID=ABC123XYZ9
CLAWPUSHRELAY_APNS_PRIVATE_KEY_PATH=./credentials/AuthKey_ABC123XYZ9.p8

# Optional. Only needed if your app's receipt validation flow requires the shared secret.
# CLAWPUSHRELAY_APPLE_RECEIPT_SHARED_SECRET=
