{
  "name": "clawpushrelay",
  "version": "0.1.0",
  "description": "Convex-backed APNs relay for official OpenClaw iOS builds",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngutman/clawpushrelay.git"
  },
  "homepage": "https://github.com/ngutman/clawpushrelay#readme",
  "bugs": {
    "url": "https://github.com/ngutman/clawpushrelay/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "convex:codegen": "convex codegen --typecheck=disable",
    "convex:deploy": "convex deploy --typecheck=disable",
    "convex:dev": "convex dev",
    "dev": "bun run convex:dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run typecheck:convex",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit"
  },
  "dependencies": {
    "convex": "^1.32.0",
    "node-app-attest": "1.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
